<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a1a"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TrustMeBro"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#00ff00"
        android:textAlignment="center"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="6 Critical Vulnerabilities"
        android:textSize="12sp"
        android:textColor="#888888"
        android:textAlignment="center"
        android:paddingBottom="24dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/backup_leak_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 1: Backup Configuration Leak"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/crypto_key_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 2: Cryptographic Key Harvesting"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/ipc_escalation_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 3: System IPC Escalation"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/database_leak_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 4: Database Leak &amp; SQL Injection"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/webview_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 5: WebView Local File Hijacking"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/overlay_capture_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 6: Compositor Overlay Capture"
                android:layout_margin="8dp"
                android:backgroundTint="#d73f3f"
                android:textColor="#ffffff" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>