<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Payment Tokenization"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Credit Card"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/credit_card_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="4532 1234 5678 9010"
                android:padding="8dp"
                android:background="#f0f0f0"
                android:layout_marginBottom="12dp"
                android:inputType="number" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Amount"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/amount_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="99.99"
                android:padding="8dp"
                android:background="#f0f0f0"
                android:layout_marginBottom="16dp"
                android:inputType="numberDecimal" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:spacing="4dp">

                <Button
                    android:id="@+id/tokenize_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tokenize"
                    android:backgroundTint="#2196F3"
                    android:textColor="#ffffff"
                    android:layout_marginEnd="2dp" />

                <Button
                    android:id="@+id/decrypt_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Decrypt"
                    android:backgroundTint="#FF9800"
                    android:textColor="#ffffff"
                    android:layout_marginStart="2dp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encrypted Token"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/encrypted_token_view"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="Token output"
                android:padding="8dp"
                android:background="#f0f0f0"
                android:layout_marginBottom="12dp"
                android:gravity="top"
                android:inputType="text"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:editable="false" />

            <TextView
                android:id="@+id/status_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready to tokenize"
                android:textSize="11sp"
                android:textColor="#333333"
                android:padding="8dp"
                android:background="#ffffcc"
                android:fontFamily="monospace" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>